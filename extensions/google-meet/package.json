{
  "name": "@agentos/google-meet",
  "version": "2026.5.3",
  "description": "AgentOS Google Meet participant plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos/agentos"
  },
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@agentos/plugin-sdk": "workspace:*",
    "agentos": "workspace:*"
  },
  "peerDependencies": {
    "agentos": ">=2026.5.3"
  },
  "peerDependenciesMeta": {
    "agentos": {
      "optional": true
    }
  },
  "agentos": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@agentos/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.3"
    },
    "build": {
      "agentosVersion": "2026.5.3"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
