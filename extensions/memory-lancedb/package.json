{
  "name": "@agentos/memory-lancedb",
  "version": "2026.5.3-1",
  "description": "AgentOS LanceDB-backed long-term memory plugin with auto-recall/capture",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos/agentos"
  },
  "type": "module",
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "apache-arrow": "18.1.0",
    "openai": "^6.35.0",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@agentos/plugin-sdk": "workspace:*"
  },
  "agentos": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@agentos/memory-lancedb",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.3"
    },
    "build": {
      "agentosVersion": "2026.5.3"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
