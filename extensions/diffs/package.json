{
  "name": "@agentos/diffs",
  "version": "2026.5.3",
  "description": "AgentOS diff viewer plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos/agentos"
  },
  "type": "module",
  "scripts": {
    "build:viewer": "bun build src/viewer-client.ts --target browser --format esm --minify --outfile assets/viewer-runtime.js"
  },
  "dependencies": {
    "@pierre/diffs": "1.1.20",
    "@pierre/theme": "0.0.29",
    "playwright-core": "1.59.1",
    "typebox": "1.1.37"
  },
  "devDependencies": {
    "@agentos/plugin-sdk": "workspace:*"
  },
  "agentos": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@agentos/diffs",
      "localPath": "extensions/diffs",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.30"
    },
    "compat": {
      "pluginApi": ">=2026.5.3"
    },
    "build": {
      "agentosVersion": "2026.5.3",
      "staticAssets": [
        {
          "source": "./assets/viewer-runtime.js",
          "output": "assets/viewer-runtime.js"
        }
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
