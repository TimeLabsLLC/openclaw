{
  "name": "@agentos/voice-call",
  "version": "2026.5.3",
  "description": "AgentOS voice-call plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentos/agentos"
  },
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "typebox": "1.1.37",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@agentos/plugin-sdk": "workspace:*",
    "agentos": "workspace:*"
  },
  "peerDependencies": {
    "agentos": ">=2026.5.3"
  },
  "peerDependenciesMeta": {
    "agentos": {
      "optional": true
    }
  },
  "agentos": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@agentos/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.3"
    },
    "build": {
      "agentosVersion": "2026.5.3"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
