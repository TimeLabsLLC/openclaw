{
  "name": "agentos-control-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "electron:dist": "electron-builder",
    "electron:pack": "electron-builder --dir",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@create-markdown/preview": "^2.0.3",
    "@noble/ed25519": "3.1.0",
    "dompurify": "^3.4.2",
    "json5": "^2.2.3",
    "lit": "^3.3.2",
    "markdown-it": "^14.1.1",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitest/browser-playwright": "4.1.5",
    "electron": "42.2.0",
    "electron-builder": "26.8.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "build": {
    "appId": "com.agentos.bios",
    "productName": "B.I.O.S",
    "electronVersion": "42.2.0",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.js",
      "package.json"
    ]
  }
}
